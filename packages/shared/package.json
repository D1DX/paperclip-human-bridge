{
  "name": "@d1dx/paperclip-gchat-bridge-shared",
  "version": "0.1.0-pre",
  "description": "Shared types, config schema, Chat + Paperclip API clients, and command parser for the paperclip-gchat-bridge",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./clients/chat": {
      "import": "./dist/clients/chat.js",
      "types": "./dist/clients/chat.d.ts"
    },
    "./clients/paperclip": {
      "import": "./dist/clients/paperclip.js",
      "types": "./dist/clients/paperclip.d.ts"
    },
    "./commands": {
      "import": "./dist/commands.js",
      "types": "./dist/commands.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
