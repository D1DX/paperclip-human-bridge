{
  "name": "@d1dx/paperclip-human-bridge-shared",
  "version": "0.1.0-pre",
  "description": "Shared types, config schema, channel registry + interface, and channel modules for the paperclip-human-bridge",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./commands": {
      "import": "./dist/commands.js",
      "types": "./dist/commands.d.ts"
    },
    "./channels": {
      "import": "./dist/channels/registry.js",
      "types": "./dist/channels/registry.d.ts"
    },
    "./channels/gchat": {
      "import": "./dist/channels/gchat/index.js",
      "types": "./dist/channels/gchat/index.d.ts"
    },
    "./channels/telegram": {
      "import": "./dist/channels/telegram/index.js"
    },
    "./channels/slack": {
      "import": "./dist/channels/slack/index.js"
    },
    "./channels/whatsapp": {
      "import": "./dist/channels/whatsapp/index.js"
    },
    "./channels/email": {
      "import": "./dist/channels/email/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "google-auth-library": "^9.15.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
